# Caddy listens on container :80; map host port in docker-compose (e.g. 8000:80).
# Set NEXT_PUBLIC_API_URL to the full URL clients use (scheme + host + port).

# Reverse-proxy password gate for the demo deployment. Generate the hash with:
# docker run --rm caddy:2.10.2 caddy hash-password --plaintext 'change-me'
BASIC_AUTH_USERNAME=demo
BASIC_AUTH_PASSWORD_HASH=

# Browser-visible API origin (same origin as the UI), e.g. http://host:8000.
NEXT_PUBLIC_API_URL=http://app.example.com:8000

# AutoDS model runtime. The backend expects OpenAI-compatible API schema only.
AUTODS_MODEL=gpt-5
AUTODS_API_KEY=change-me
AUTODS_BASE_URL=https://api.openai.com/v1
AUTODS_MAX_RETRIES=3
AUTODS_MODEL_KWARGS_JSON=
AUTODS_EXTRA_BODY_JSON=
AUTODS_DEFAULT_HEADERS_JSON=

# Optional bind-mount roots for persistent data outside Docker's loop device.
# Defaults are relative to this directory: docker/data/{autods,pygrad,uv-cache}
# AUTODS_DATA_DIR=./data/autods
# PYGRAD_DATA_DIR=./data/pygrad
# UV_CACHE_DATA_DIR=./data/uv-cache

# Prefer CPU PyTorch wheels in session venvs to avoid multi-GB CUDA downloads.
AUTODS_PIP_EXTRA_INDEX_URL=https://download.pytorch.org/whl/cpu

# Graph backend.
SEARCH_BACKEND=neo4j-graphrag
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j

# Pygrad GraphRAG model configuration.
# If Ollama runs in Docker, use the Docker service hostname instead of localhost.
LLM_PROVIDER=ollama
LLM_MODEL=qwen3-coder:30b
LLM_API_KEY=ollama
LLM_ENDPOINT=http://ollama:11434/v1

EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=embeddinggemma:latest
EMBEDDING_ENDPOINT=http://ollama:11434/api/embed
EMBEDDING_DIMENSIONS=768
EMBEDDING_API_KEY=

# Currently documented for pygrad setups but not consumed by app code directly.
HUGGINGFACE_TOKENIZER=Qwen/Qwen3-Coder-30B-A3B-Instruct

# App-level auth. Keep this disabled when you rely on the Caddy password gate.
AUTH_MODE=disabled
AUTH_SECRET=change-me
AUTH_COOKIE_SECURE=true
CLI_TOKEN_SECRET=
AUTH_BOOTSTRAP_ADMIN_EMAILS=admin@example.com

# Optional WorkOS settings if you want hosted auth instead of the shared
# reverse-proxy password gate.
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_REDIRECT_URI=https://app.example.com/api/auth/callback
WORKOS_COOKIE_PASSWORD=
