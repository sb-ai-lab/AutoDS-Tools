# Public host served by the reverse proxy.
PUBLIC_HOST=app.example.com

# Browser-visible API origin. In the recommended same-origin setup this should
# match the public host, for example https://app.example.com.
NEXT_PUBLIC_API_URL=https://app.example.com

# AutoDS model runtime. The backend expects OpenAI-compatible API schema only.
AUTODS_MODEL=gpt-5
AUTODS_API_KEY=change-me
AUTODS_BASE_URL=https://api.openai.com/v1
AUTODS_MAX_RETRIES=3
AUTODS_MODEL_KWARGS_JSON=
AUTODS_EXTRA_BODY_JSON=
AUTODS_DEFAULT_HEADERS_JSON=

# Graph backend.
SEARCH_BACKEND=neo4j-graphrag
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j

# Pygrad GraphRAG model configuration.
# If Ollama runs in Docker, use the Docker service hostname instead of localhost.
LLM_PROVIDER=ollama
LLM_MODEL=qwen3-coder:30b
LLM_API_KEY=ollama
LLM_ENDPOINT=http://ollama:11434/v1

EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=embeddinggemma:latest
EMBEDDING_ENDPOINT=http://ollama:11434/api/embed
EMBEDDING_DIMENSIONS=768
EMBEDDING_API_KEY=

# Currently documented for pygrad setups but not consumed by app code directly.
HUGGINGFACE_TOKENIZER=Qwen/Qwen3-Coder-30B-A3B-Instruct

# Hosted auth.
AUTH_MODE=workos
AUTH_SECRET=change-me
WORKOS_CLIENT_ID=client_123
WORKOS_API_KEY=sk_test_123
WORKOS_REDIRECT_URI=https://app.example.com/api/auth/callback
WORKOS_COOKIE_PASSWORD=
AUTH_COOKIE_SECURE=true
CLI_TOKEN_SECRET=
AUTH_BOOTSTRAP_ADMIN_EMAILS=admin@example.com
